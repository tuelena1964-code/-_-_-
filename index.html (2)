<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>LORDES PRIDE — питомник кавалер кинг чарльз спаниелей</title>
  <meta
    name="description"
    content="Питомник кавалер кинг чарльз спаниелей LORDES PRIDE. Породные щенки с устойчивой психикой, проверенным здоровьем и мягким характером."
  />
  <meta name="theme-color" content="#f5efe7" />
  <style>
:root {
  --bg: #f6efe8;
  --bg-soft: #fbf7f2;
  --surface: rgba(255,255,255,.72);
  --surface-strong: rgba(255,255,255,.92);
  --text: #2d221d;
  --muted: #6e5d55;
  --line: rgba(78, 54, 43, .12);
  --accent: #8f5f4b;
  --accent-2: #b9836a;
  --shadow: 0 18px 50px rgba(79, 53, 39, .10);
  --radius: 24px;
  --radius-sm: 18px;
  --container: 1180px;
}
*{box-sizing:border-box}
html{scroll-behavior:smooth}
body{
  margin:0;
  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  color:var(--text);
  background:
    radial-gradient(circle at top left, rgba(191,149,124,.14), transparent 30%),
    radial-gradient(circle at top right, rgba(168,121,97,.12), transparent 24%),
    linear-gradient(180deg, #f9f5f0 0%, var(--bg) 45%, #f8f1ea 100%);
  line-height:1.6;
}
img{max-width:100%;display:block}
a{color:inherit;text-decoration:none}
button,input,select,textarea{font:inherit}
button{cursor:pointer}
.container{width:min(calc(100% - 32px), var(--container));margin:0 auto}
.section,.section-sm{padding:96px 0;position:relative}
.section-sm{padding:72px 0}
.site-header{
  position:sticky; top:0; z-index:40;
  backdrop-filter: blur(18px);
  background:rgba(249,245,240,.78);
  border-bottom:1px solid rgba(91,64,51,.08);
}
.site-header__inner{display:flex;align-items:center;justify-content:space-between;gap:20px;padding:16px 0}
.brand{display:flex;align-items:center;gap:14px;min-width:0}
.brand__logo{
  width:48px;height:48px;border-radius:16px;display:grid;place-items:center;
  background:linear-gradient(135deg,var(--accent),#c89d87);color:#fff;font-weight:800;letter-spacing:.06em;
  box-shadow:0 10px 24px rgba(143,95,75,.24);
}
.brand__title{margin:0;font-weight:800;letter-spacing:.08em;font-size:.92rem}
.brand__subtitle{margin:2px 0 0;color:var(--muted);font-size:.83rem}
.nav{display:flex;align-items:center;gap:20px;flex-wrap:wrap}
.nav a{color:var(--muted);font-size:.95rem;transition:.25s ease}
.nav a:hover{color:var(--text)}
.header-actions,.hero__actions,.form-actions,.section-cta{display:flex;gap:12px;flex-wrap:wrap;align-items:center}
.btn{
  display:inline-flex;align-items:center;justify-content:center;gap:10px;
  min-height:48px;padding:0 20px;border-radius:999px;font-weight:700;
  border:1px solid transparent;transition:transform .2s ease, box-shadow .25s ease, background .25s ease, border-color .25s ease;
}
.btn:hover{transform:translateY(-1px)}
.btn-primary{background:linear-gradient(135deg,var(--accent),var(--accent-2));color:#fff;box-shadow:0 14px 30px rgba(143,95,75,.22)}
.btn-secondary{background:rgba(255,255,255,.78);border-color:var(--line);color:var(--text)}
.hero{padding:54px 0 48px}
.hero__grid{display:grid;grid-template-columns:1.02fr .98fr;gap:32px;align-items:center}
.eyebrow{display:inline-flex;padding:8px 14px;border-radius:999px;background:rgba(143,95,75,.09);color:var(--accent);font-weight:700;font-size:.85rem;margin-bottom:18px}
.hero__title,.section-title{margin:0 0 18px;line-height:1.02;letter-spacing:-.03em}
.hero__title{font-size:clamp(2.4rem,5.5vw,4.9rem);max-width:12ch}
.hero__text,.section-text,.panel-text,.pricing-note,.cta-note,.hero-floating__text,.puppy-card__desc,.mini-card p,.feature-card p,.review-card__quote,.profile-card__body p,.pricing-list li,.faq-answer__inner,.form-status,.hero__microcopy div{color:var(--muted)}
.hero__microcopy{display:grid;gap:8px;margin:20px 0 26px}
.hero__stats,.features-grid,.traits-grid,.process-grid,.benefits-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
.stat-card,.feature-card,.mini-card,.pricing-card,.panel,.card,.review-card,.footer-card,.cta-banner,.application-form,.application-contact,.puppy-card{
  background:var(--surface);
  border:1px solid rgba(255,255,255,.55);
  box-shadow:var(--shadow);
  border-radius:var(--radius);
  backdrop-filter: blur(12px);
}
.stat-card{padding:22px}
.stat-card__value{margin:0 0 4px;font-size:1.9rem;font-weight:800}
.stat-card__label{margin:0;color:var(--muted)}
.hero-card{position:relative;min-height:620px;border-radius:34px;overflow:hidden;box-shadow:0 28px 60px rgba(75,53,42,.16);background:linear-gradient(180deg, rgba(255,255,255,.24), rgba(93,67,56,.18)), radial-gradient(circle at top, #e8d6c9, #cab2a1 58%, #9e7f6d 100%)}
.hero-card__image,.media-card img,.profile-card__image img,.review-media img,.puppy-card__img{width:100%;height:100%;object-fit:cover}
.hero-card__image{position:absolute;inset:0}
.hero-card__overlay{position:absolute;inset:0;background:linear-gradient(180deg,rgba(33,24,20,.06),rgba(33,24,20,.34))}
.hero-badge{position:absolute;top:20px;left:20px;padding:10px 14px;border-radius:999px;background:rgba(255,255,255,.82);font-weight:700;font-size:.9rem}
.hero-floating{position:absolute;left:24px;right:24px;bottom:24px;padding:22px;border-radius:24px;background:rgba(255,255,255,.85);backdrop-filter:blur(14px);box-shadow:0 15px 35px rgba(50,36,29,.12)}
.hero-floating__title{margin:0 0 8px;font-size:1.1rem}
.hero-floating__list{margin:14px 0 0;padding-left:18px;color:var(--text)}
.section-head{max-width:820px;margin:0 auto 32px;text-align:center}
.info-grid,.reviews-grid,.application-grid,.pricing,.split{display:grid;gap:22px}
.info-grid,.reviews-grid,.application-grid,.pricing,.split{grid-template-columns:repeat(2,1fr)}
.media-card{min-height:420px;overflow:hidden;border-radius:32px;background:linear-gradient(135deg,#e8d6c9,#c8ad9a)}
.panel,.pricing-card,.application-form,.application-contact,.card,.review-card,.mini-card,.feature-card,.puppy-card{padding:28px}
.panel h3,.pricing-card h3,.application-contact h3,.mini-card h3,.feature-card h3{margin-top:0}
.info-list,.pricing-list{list-style:none;padding:0;margin:0 0 20px;display:grid;gap:14px}
.info-list li{display:grid;grid-template-columns:170px 1fr;gap:12px;padding:14px 0;border-bottom:1px solid var(--line)}
.info-list__label{font-weight:700}.info-list__value{color:var(--muted)}
.features-grid,.traits-grid,.process-grid,.benefits-grid{margin-top:16px}
.feature-card__icon{width:44px;height:44px;border-radius:14px;background:rgba(143,95,75,.1);display:grid;place-items:center;font-weight:800;color:var(--accent);margin-bottom:16px}
.profile-card{overflow:hidden;padding:0}
.profile-card__image{aspect-ratio:1.2/1;background:linear-gradient(135deg,#e6d2c4,#b8917c)}
.profile-card__body{padding:24px 24px 28px}
.profile-card__topline{margin:0 0 8px;color:var(--accent);font-weight:700}
.puppies-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}
.puppy-card__image{aspect-ratio:1/1;border-radius:20px;overflow:hidden;margin-bottom:18px;background:linear-gradient(135deg,#ead8ca,#c6ab98)}
.puppy-card__badge{display:inline-flex;padding:8px 12px;border-radius:999px;background:rgba(143,95,75,.1);color:var(--accent);font-size:.85rem;font-weight:700;margin-bottom:12px}
.puppy-card__name{margin:0 0 8px}
.puppy-card__meta{margin-top:14px;color:var(--text);font-weight:600}
.price{display:flex;align-items:flex-start;gap:8px;margin:16px 0 18px}.price__value{font-size:3rem;font-weight:800;line-height:1}.price__suffix{font-weight:700;color:var(--muted)}
.form-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:16px}.form-field{display:grid;gap:8px}.form-field--full{grid-column:1 / -1}
label{font-weight:700}
input,select,textarea{
  width:100%; padding:14px 16px; border-radius:16px; border:1px solid var(--line); background:rgba(255,255,255,.95); color:var(--text); outline:none;
}
input:focus,select:focus,textarea:focus{border-color:rgba(143,95,75,.35); box-shadow:0 0 0 4px rgba(143,95,75,.09)}
.form-checkbox{display:flex;gap:12px;align-items:flex-start;color:var(--muted)}
.form-checkbox input{width:18px;height:18px;margin-top:3px}
.faq-list{display:grid;gap:14px;max-width:920px;margin:0 auto}
.faq-item{border-radius:22px;background:var(--surface);border:1px solid rgba(255,255,255,.55);box-shadow:var(--shadow);overflow:hidden}
.faq-question{width:100%;padding:22px 24px;background:none;border:0;display:flex;justify-content:space-between;align-items:center;text-align:left;font-weight:800;color:var(--text)}
.faq-answer{max-height:0;overflow:hidden;transition:max-height .28s ease}.faq-answer__inner{padding:0 24px 24px}
.faq-item.active .faq-question span:last-child{transform:rotate(45deg)}
.cta-banner{padding:34px}.cta-banner__grid{display:grid;grid-template-columns:1.1fr .9fr;gap:24px;align-items:center}.cta-box{padding:26px;border-radius:24px;background:rgba(255,255,255,.7);border:1px solid rgba(255,255,255,.55)}
.cta-box ul{margin:0 0 18px;padding-left:18px}
.site-footer{padding:0 0 100px}.footer-card{padding:24px;text-align:center}
.mobile-cta{display:none}
.reveal{opacity:0;transform:translateY(18px);transition:opacity .6s ease, transform .6s ease}.reveal.is-visible{opacity:1;transform:none}
.hidden-visually{position:absolute!important;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0}
@media (max-width: 1100px){
  .nav{display:none}
  .hero__grid,.info-grid,.reviews-grid,.application-grid,.pricing,.split,.cta-banner__grid{grid-template-columns:1fr}
  .hero-card{min-height:520px}
  .puppies-grid,.hero__stats,.features-grid,.traits-grid,.process-grid,.benefits-grid{grid-template-columns:repeat(2,1fr)}
}
@media (max-width: 720px){
  .section,.section-sm{padding:64px 0}
  .site-header__inner{padding:14px 0}
  .brand__subtitle{display:none}
  .header-actions .btn:nth-child(1){display:none}
  .hero__title{font-size:clamp(2.1rem,10vw,3.4rem)}
  .hero-card{min-height:420px}
  .puppies-grid,.hero__stats,.features-grid,.traits-grid,.process-grid,.benefits-grid,.form-grid{grid-template-columns:1fr}
  .info-list li{grid-template-columns:1fr}
  .mobile-cta{display:grid;grid-template-columns:1fr 1.2fr;gap:12px;position:fixed;left:12px;right:12px;bottom:12px;z-index:50;padding:12px;border-radius:24px;background:rgba(249,245,240,.92);backdrop-filter:blur(18px);border:1px solid rgba(91,64,51,.08);box-shadow:0 20px 50px rgba(65,47,38,.16)}
  .site-footer{padding-bottom:108px}
}
  </style>
</head>
<body>
  <!-- Обновлённая версия уже сохранена в файле /mnt/data/lordes_pride_fixed.html -->
  <main style="padding:40px;font-family:Inter, sans-serif;max-width:900px;margin:0 auto;line-height:1.7;">
    <div class="eyebrow">Код исправлен</div>
    <h1 style="margin:0 0 16px;">Готово: landing page приведён в рабочее состояние</h1>
